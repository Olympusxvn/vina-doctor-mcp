# ── MCP Server ────────────────────────────────────────────────────────────────
# Base URL of the AI Engine (Docker internal DNS or localhost for dev)
AI_ENGINE_BASE_URL=http://ai_engine:8000

# Transport: "stdio" for local dev, "streamable-http" for production
MCP_TRANSPORT=stdio

# Host and port for streamable-http transport
MCP_HOST=0.0.0.0
MCP_PORT=8002
